; Input Variable Declarations (4 inputs)
(declare-const X_0 Real)
(declare-const X_1 Real)
(declare-const X_2 Real)
(declare-const X_3 Real)

(declare-const Y_0 Real)
(declare-const Y_1 Real)

; X_1 is between 3 and 4
(assert (<= X_0 3.1))
(assert (>= X_0 2.9))

(assert (<= X_1 3.1))
(assert (>= X_1 2.9))

(assert (<= X_2 0.0))
(assert (>= X_2 0.0))

(assert (<= X_3 0.0))
(assert (>= X_3 0.0))

(assert (or
    (and (>= Y_0 1) (<= Y_0 2))
    (and (>= Y_1 1) (<= Y_1 2))
))