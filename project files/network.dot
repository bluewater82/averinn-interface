        neg_m -> neg_s [color="#FFA50099"];
        neg_s -> neg_end [color="#FFA500FF"];

        { rank=same; pos_label; pos_w; pos_m; pos_s; pos_end; }
        { rank=same; neg_label; neg_w; neg_m; neg_s; neg_end; }
    }

